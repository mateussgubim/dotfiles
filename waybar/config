[
  {
    "output": ["HDMI-A-1", "DP-1", "eDP-1"],
    "layer": "top",
    "position": "top",
    "height": 34,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["custom/notification", "clock", "sway/language"],
    "modules-right": ["group/hardware", "wireplumber", "network", "tray", "custom/power"],
    
    "sway/language": {
      "format": "{}",
      "min-length": 5,
      "on-click": "sway msg input type:keyboard xkb_switch_layout next"
    },

    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "format": "{icon}",
      "format-icons": {
        "focused": "’äæ",
        "default": "’äī"
      }
    },

    "clock": {
      "format": "{:%H:%M}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
    },

    "custom/notification": {
    "tooltip": false,
    "format": "{icon} ",
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
    },

    "group/hardware": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 500,
        "children-class": "hidden",
        "transition-left-to-right": false
      },
      "modules": ["cpu", "memory", "battery"]
    },

    "cpu": {
      "format": "’ŗø {usage}%",
      "interval": 5
    },

    "memory": {
      "format": "¾░Źø {used:0.1f}G",
      "interval": 5
    },

    "wireplumber": {
      "format": "{icon} {volume}%",
      "format-muted": " ¾░Ø¤ ",
      "scroll-step": 5,
      "format-icons": ["’Ć”", "’Ć¦", "’Ć©"],
      "on-click": "pavucontrol"
    },

    "network": {
      "format-wifi": "’ć½  {signalStrength}%",
      "format-ethernet": " ¾░łĆ ",
      "format-disconnected": " ¾░¢¬ ",
      "tool-tip": "{essid} via {ifname}",
      "on-click": "nm-connection-editor"
    },

    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"]
    },

    "spacing": 2,
    "tray": {
      "icon-size": 18,
      "spacing": 5
    },

    "custom/power": {
      "format": "ŌÅ╗ ",
      "tooltip": false,
      "menu": "on-click",
      "menu-file": "$HOME/.config/waybar/power_menu.xml",
      "menu-actions": {
          "lock": "hyprlock",
          "shutdown": "systemctl poweroff",
          "reboot": "systemctl reboot",
          "suspend": "systemctl suspend",
          "hibernate": "systemctl hibernate"
      }
    }
  }
]
